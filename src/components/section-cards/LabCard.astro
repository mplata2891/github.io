---
// src/components/LabCard.astro
import { Code } from 'astro:components';

const { lab } = Astro.props;
const modalId = `modal-${lab.id}`;
---

{/* 1. OUTER WRAPPER: Hover state is Purple */}
<article class="bg-void border border-[var(--color-border-subtle)] rounded-sm overflow-hidden flex flex-col relative h-full group hover:border-accent transition-all duration-300">
  
  {/* --- LOG HEADER --- */}
  <div class="bg-surface border-b border-[var(--color-border-subtle)] p-6 flex flex-col md:flex-row md:justify-between md:items-start gap-4">
    <div>
      <div class="flex items-center gap-3 mb-2">
        {/* Lab ID in Purple */}
        <span class="font-mono text-sm text-accent">[{lab.id}]</span>
        <span class="font-mono text-xs uppercase px-2 py-0.5 border border-[var(--color-border-subtle)] text-text-secondary rounded-sm">
          TYPE: {lab.type}
        </span>
      </div>
      {/* Chakra Petch (Display) for the Lab Name, interacting with Purple */}
      <h3 class="text-xl font-display font-bold tracking-wide text-text-primary mb-1 group-hover:text-accent transition-colors">{lab.courseName}</h3>
      <p class="font-mono text-sm text-text-secondary uppercase">// INSTRUCTOR: {lab.professor}</p>
    </div>
    
    <div class="flex flex-wrap gap-2 md:max-w-xs justify-start md:justify-end">
      {lab.tags.map((tag) => (
        <span class="font-mono text-xs text-text-secondary bg-industrial/20 px-2 py-1 rounded-sm border border-[var(--color-border-subtle)]/50">
          #{tag}
        </span>
      ))}
    </div>
  </div>

  {/* --- LOG BODY --- */}
  <div class="p-6 grid grid-cols-1 lg:grid-cols-2 gap-8 flex-grow">
    
    {/* LEFT COLUMN: Text Content */}
    <div class="flex flex-col gap-6">
      <div>
        <h4 class="font-mono text-sm text-text-secondary mb-2">// THE_PROBLEM</h4>
        <p class="font-sans text-text-primary leading-relaxed text-sm">{lab.problem}</p>
      </div>
      <div>
        <h4 class="font-mono text-sm text-accent mb-2">// THE_SOLUTION</h4>
        <p class="font-sans text-text-primary leading-relaxed text-sm">{lab.solution}</p>
      </div>
    </div>

    {/* RIGHT COLUMN: Code / Hardware Render */}
    <div class="flex flex-col h-full">
      
      {/* SOFTWARE RENDER */}
      {lab.type === 'software' && (
        <div class="bg-surface border border-[var(--color-border-subtle)] rounded-sm p-0 w-full flex flex-col h-full group/terminal hover:border-accent/50 transition-colors">
          <div class="flex justify-between items-center px-4 py-2 border-b border-[var(--color-border-subtle)] bg-surface-highlight">
            <p class="font-mono text-xs text-phosphor uppercase">
              {lab.primaryLanguage} | <a href={lab.repoUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">view_repo</a>
            </p>
            <div class="flex gap-2">
              <div class="w-2 h-2 rounded-full bg-industrial"></div>
              <div class="w-2 h-2 rounded-full bg-industrial"></div>
              {/* FUNCTIONAL: Keeping the Phosphor Green LED here to indicate "System Active" */}
              <div class="w-2 h-2 rounded-full bg-phosphor animate-pulse shadow-[0_0_8px_var(--color-phosphor)]"></div>
            </div>
          </div>
          
          <div class="p-4 bg-[#282a36] h-64 overflow-y-auto lab-scrollbar">
            <div class="font-mono text-xs [&>pre]:!bg-transparent [&>pre]:whitespace-pre-wrap">
              <Code code={lab.codeSnippet} lang={lab.primaryLanguage} theme="dracula" />
            </div>
          </div>

          {lab.fullCode && (
            <button 
              onclick={`document.getElementById('${modalId}').showModal()`}
              class="w-full mt-auto py-3 border-t border-[var(--color-border-subtle)] bg-surface-highlight hover:bg-accent/10 transition-colors font-mono text-xs text-text-secondary text-center uppercase tracking-widest group/btn"
            >
              <span class="group-hover/btn:text-accent-hover transition-colors">>> EXPAND_FULL_CODE</span>
            </button>
          )}
        </div>
      )}

      {/* HARDWARE RENDER */}
      {lab.type === 'hardware' && (
        <div class="flex flex-col gap-4 h-full justify-between">
          <div class="border border-[var(--color-border-subtle)] bg-surface p-2 rounded-sm relative group/hw overflow-hidden hover:border-accent/50 transition-colors">
            <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover/hw:opacity-100 transition-opacity z-10 pointer-events-none"></div>
            <img 
              src={lab.schematicAsset} 
              alt={`Schematic for ${lab.courseName}`}
              class="w-full h-auto object-cover grayscale mix-blend-luminosity group-hover/hw:grayscale-0 transition-all duration-500 relative z-0"
            />
          </div>
          
          <div class="flex flex-wrap gap-2 mt-auto">
            <span class="font-mono text-xs text-text-secondary uppercase">SPECS:</span>
            {lab.hardwareSpecs?.map((spec) => (
              <span class="font-mono text-xs text-accent bg-accent/10 border border-accent/20 px-2 py-0.5 rounded-sm">
                {spec}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  {/* --- TRUE GLASSMORPHIC MODAL --- */}
  {lab.type === 'software' && lab.fullCode && (
    <dialog 
      id={modalId} 
      class="fixed inset-0 m-auto w-11/12 max-w-5xl bg-void/40 backdrop-blur-2xl border border-white/10 border-t-2 border-t-accent rounded-lg shadow-[0_8px_32px_rgba(0,0,0,0.5)] text-text-primary backdrop:bg-black/80 backdrop:backdrop-blur-sm p-0 overflow-hidden"
    >
      <div class="flex justify-between items-center px-4 py-3 border-b border-white/10 bg-surface/30 z-10">
        <div class="flex items-center gap-4">
          <div class="flex gap-1.5">
            <div class="w-2 h-2 rounded-full bg-[var(--color-border-subtle)]"></div>
            <div class="w-2 h-2 rounded-full bg-[var(--color-border-subtle)]"></div>
            <div class="w-2 h-2 rounded-full bg-accent animate-pulse"
              style="box-shadow: 0 0 6px var(--color-accent-glow);"></div>
          </div>
          <p class="font-mono text-xs text-text-secondary mt-0.5 opacity-80 uppercase tracking-widest">
            ~/{lab.courseName.replace(/\s+/g, '_').toLowerCase()}/main.{lab.primaryLanguage}
          </p>
        </div>
        
        <form method="dialog">
          {/* FUNCTIONAL: Using Critical Red for the Close/Exit button */}
          <button class="font-mono text-xs text-critical hover:text-void transition-colors px-2 py-1 rounded-sm border border-transparent hover:border-critical bg-transparent hover:bg-critical focus:outline-none">
            [ ESC ] CLOSE
          </button>
        </form>
      </div>
      
      <div class="p-6 overflow-y-auto max-h-[75vh] bg-[#282a36]/30 lab-scrollbar">
        <div class="font-mono text-sm [&>pre]:!bg-transparent">
          <Code code={lab.fullCode} lang={lab.primaryLanguage} theme="dracula" />
        </div>
      </div>
    </dialog>
  )}

</article>

<style>
  .lab-scrollbar::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  .lab-scrollbar::-webkit-scrollbar-track {
    background: #1e1e2e; 
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }
  .lab-scrollbar::-webkit-scrollbar-thumb {
    background: #313244; 
    border-radius: 4px;
  }
  .lab-scrollbar::-webkit-scrollbar-thumb:hover {
    background: var(--color-accent); 
  }
</style>