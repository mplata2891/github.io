---
// src/components/Experience.astro
import { EXPERIENCE, EXPERIENCE_DESCRIPTION } from '../data/experience.js';
import ExperienceCard from './section-cards/ExperienceCard.astro';
import SysCarousel from './system/SysCarousel.astro';
import HardwareNode from './ui/HardwareNode.astro'; 
---

<section id="experience" class="flex flex-col w-full scroll-mt-24 mb-16 deploy-hidden">
  
  {/* SECTION HEADER */}
  <div class="flex items-center mb-4 w-full">
    
    <div class="relative flex items-center">
      <div class="trace-connector hidden lg:block z-0"></div>
      
      <HardwareNode class="text-accent hidden lg:block relative z-10 mr-4 bg-void" />
      
      <h2 class="text-2xl font-bold tracking-tight uppercase">EXPERIENCE</h2>
    </div>

    <div class="h-[1px] flex-grow bg-industrial ml-4"></div>
    <p class="font-mono text-sm text-text-secondary uppercase ml-4">
      Operational_Logs_v1.0
    </p>
    
  </div>

  {/* DYNAMIC CONTEXT PARAGRAPH */}
  <p class="text-text-secondary leading-relaxed mb-8 w-full">
    {EXPERIENCE_DESCRIPTION}
  </p>

  {/* CAROUSEL */}
  <SysCarousel>
    {EXPERIENCE.map((job) => (
      <div class="w-full md:w-[85%] flex-shrink-0 snap-center flex flex-col h-full">
        <ExperienceCard job={job} />
      </div>
    ))}
  </SysCarousel>

</section>