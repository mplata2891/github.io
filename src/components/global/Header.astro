---
// src/components/global/Header.astro
import { HEADER } from '../../data/header.js';

// Abstracted classes to clean up the HTML layer
const linkStyle = [
  "font-mono text-sm text-text-secondary uppercase",
  "tracking-widest hover:text-accent-hover transition-colors",
  "glitch-hover"
].join(" ");

const buttonStyle = [
  "px-4 py-2 border border-industrial font-mono text-sm",
  "bg-surface text-text-primary uppercase tracking-widest",
  "hover:border-accent hover:text-accent transition-all",
  "glitch-hover w-full md:w-auto text-center"
].join(" ");

const desktopNav = "hidden md:flex items-center gap-6";

const mobileNav = [
  "absolute top-full left-0 w-full bg-void border-b",
  "border-industrial flex-col items-center gap-6 py-6",
  "hidden z-40 shadow-[0_10px_30px_rgba(0,0,0,0.8)]"
].join(" ");
---

<header class:list={[
  "w-full px-6 py-6 flex justify-between items-center border-b",
  "border-industrial bg-void z-50 relative"
]}>
  
  {/* SYSTEM IDENTITY */}
  <div class="flex items-center gap-3 group cursor-pointer">
    <div class:list={[
      "w-8 h-8 bg-surface border border-industrial flex items-center",
      "justify-center group-hover:border-accent transition-colors"
    ]}>
      <span class="font-mono text-sm text-accent font-bold">
        {HEADER.initials}
      </span>
    </div>
    <span class:list={[
      "font-mono text-base tracking-widest text-text-primary",
      "uppercase hidden md:block"
    ]}>
      {HEADER.systemName}
    </span>
  </div>

  {/* DESKTOP COMM ARRAY */}
  <div class={desktopNav}>
    {HEADER.navLinks.map((link) => (
      <a href={link.url} target="_blank" class={linkStyle}>
        {link.label}
      </a>
    ))}
    <a href={HEADER.actionButton.url} target="_blank" class={buttonStyle}>
      {HEADER.actionButton.label}
    </a>
  </div>

  {/* MOBILE HAMBURGER TOGGLE */}
  <button 
    id="mobile-menu-btn" 
    aria-label="Toggle Menu"
    class:list={[
      "flex md:hidden flex-col justify-center items-center",
      "gap-1.5 w-8 h-8 focus:outline-none z-50"
    ]}
  >
    <div class="w-6 h-0.5 bg-accent transition-all duration-300"></div>
    <div class="w-6 h-0.5 bg-accent transition-all duration-300"></div>
    <div class="w-6 h-0.5 bg-accent transition-all duration-300"></div>
  </button>

  {/* MOBILE DROPDOWN MODULE */}
  <div id="mobile-menu" class={mobileNav}>
    {HEADER.navLinks.map((link) => (
      <a href={link.url} target="_blank" class={linkStyle}>
        {link.label}
      </a>
    ))}
    <a href={HEADER.actionButton.url} target="_blank" class={buttonStyle}>
      {HEADER.actionButton.label}
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      // Toggle the dropdown visibility
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
      
      // Animate the hamburger lines into an 'X'
      const lines = btn.querySelectorAll('div');
      lines[0].classList.toggle('translate-y-2');
      lines[0].classList.toggle('rotate-45');
      lines[1].classList.toggle('opacity-0');
      lines[2].classList.toggle('-translate-y-2');
      lines[2].classList.toggle('-rotate-45');
    });
  }
</script>