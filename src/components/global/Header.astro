---
// src/components/Header.astro
import { HEADER } from '../../data/header.js';

// Abstracted repetitive classes to clean up the HTML layer
const linkStyle = [
  "font-mono text-sm text-text-secondary uppercase tracking-widest",
  "hover:text-accent-hover transition-colors", "glitch-hover"
].join(" ");

const buttonStyle = [
  "px-4 py-2 border border-industrial font-mono text-sm bg-surface",
  "text-text-primary uppercase tracking-widest hover:border-accent",
  "hover:text-accent transition-all", "glitch-hover"
].join(" ");
---

<header class:list={[
  "w-full px-6 py-6 flex justify-between items-center border-b",
  "border-industrial bg-void z-40 relative"
]}>
  
  <div class="flex items-center gap-3 group cursor-pointer">
    <div class:list={[
      "w-8 h-8 bg-surface border border-industrial flex items-center",
      "justify-center group-hover:border-accent transition-colors"
    ]}>
      <span class="font-mono text-sm text-accent font-bold">
        {HEADER.initials}
      </span>
    </div>
    <span class:list={[
      "font-mono text-base tracking-widest text-text-primary",
      "uppercase hidden md:block"
    ]}>
      {HEADER.systemName}
    </span>
  </div>

  <div class="flex items-center gap-6">
    {HEADER.navLinks.map((link) => (
      <a href={link.url} target="_blank" class={linkStyle}>
        {link.label}
      </a>
    ))}
    
    <a href={HEADER.actionButton.url} target="_blank" class={buttonStyle}>
      {HEADER.actionButton.label}
    </a>
  </div>
</header>