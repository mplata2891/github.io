---
// src/components/system/BootScreen.astro
---

<div id="boot-screen" class="fixed inset-0 z-[9999] bg-void flex flex-col justify-center p-6 md:p-12 font-mono text-sm md:text-base pointer-events-auto transition-opacity duration-500">
  <div class="max-w-3xl w-full mx-auto flex flex-col gap-1">
    
    {/* The container where the logs will be injected */}
    <div id="boot-log" class="flex flex-col gap-1 text-text-secondary"></div>
    
    {/* The active terminal cursor */}
    <div id="boot-cursor" class="w-3 h-5 bg-phosphor animate-blink mt-2"></div>
    
  </div>
</div>

<script>
  const bootScreen = document.getElementById('boot-screen');
  const bootLog = document.getElementById('boot-log');

  const logs = [
    "INITIALIZING ASTRO_CORE V5.0...",
    "MOUNTING IDENTITY_FRAGMENT [HERO]...",
    "FETCHING DEPLOYMENT_LOGS [PROJECTS]...",
    "SYNCHRONIZING OPERATIONAL_RECORDS [EXPERIENCE]...",
    "LOADING EXECUTION_LOGS [LAB_ARCHIVE]...",
    "PARSING INSTRUCTION_SET [THEORY_LOGS]...",
    "VERIFYING BASE_PARAMETERS [CREDENTIALS]...",
    "COMPILING ORIGIN_STORY [ABOUT]...",
    "HYDRATING SYSTEM_INTERFACE..."
  ];

  const runBootSequence = async () => {
    if (sessionStorage.getItem('system_booted') === 'true') {
      if (bootScreen) bootScreen.style.display = 'none';
      return;
    }

    const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

    // 1. Run the boot logs
    for (let i = 0; i < logs.length; i++) {
      const line = document.createElement('div');
      line.innerHTML = `<span class="text-telemetry">></span> ${logs[i]}`;
      bootLog.appendChild(line);
      
      await sleep(Math.random() * 200 + 100);

      if (i === logs.length - 1) {
         line.innerHTML += ` <span class="text-phosphor font-bold">[ READY ]</span>`;
         await sleep(500);
      } else if (i === 4) {
         line.innerHTML += ` <span class="text-critical font-bold">[ FAIL ]</span>`;
         await sleep(400);
         const retryLine = document.createElement('div');
         retryLine.innerHTML = `<span class="text-alert">></span> RETRYING MEMORY ALLOCATION... <span class="text-phosphor font-bold">[ OK ]</span>`;
         bootLog.appendChild(retryLine);
         await sleep(200);
      } else {
         line.innerHTML += ` <span class="text-phosphor font-bold">[ OK ]</span>`;
      }
    }

    // 2. LINGER & COUNTDOWN
    const countdownLine = document.createElement('div');
    countdownLine.className = 'mt-4 text-alert font-bold'; // Gives it some spacing and uses the Amber color
    bootLog.appendChild(countdownLine);

    for (let c = 5; c > 0; c--) {
      countdownLine.innerHTML = `> HANDSHAKE COMPLETE. DEPLOYING IN T-MINUS ${c}...`;
      await sleep(800); // 800ms feels snappy but readable
    }
    
    countdownLine.innerHTML = `> EXECUTING...`;
    await sleep(300);

    // 3. Fade out the overlay
    bootScreen.style.opacity = '0';
    
    setTimeout(() => {
      bootScreen.style.display = 'none';
      sessionStorage.setItem('system_booted', 'true');
    }, 500);
  };

  document.addEventListener('DOMContentLoaded', runBootSequence);
</script>