---
// src/components/system/SysCarousel.astro

const mobileBtn = [
  "prev-btn sm:hidden absolute z-10 top-1/2 -translate-y-1/2",
  "px-2 py-6 bg-void/90 border border-industrial text-text-secondary",
  "hover:text-accent hover:border-accent backdrop-blur-sm transition-all"
].join(" ");

const desktopBtn = [
  "font-mono text-sm text-text-secondary hover:text-accent",
  "transition-colors"
].join(" ");
---

<sys-carousel class="flex flex-col w-full group/carousel relative">
  
  {/* 1. TRACK WRAPPER (For Mobile Arrows) */}
  <div class="relative w-full flex items-center">
    
    {/* Mobile Prev Arrow */}
    <button class:list={[mobileBtn, "left-0 border-l-0 prev-btn"]}>
      &lt;
    </button>

    <div class:list={[
      "carousel-track flex overflow-x-auto snap-x snap-mandatory gap-6",
      "pb-4 hide-scrollbar items-stretch w-full"
    ]}>
      <slot />
    </div>

    {/* Mobile Next Arrow */}
    <button class:list={[mobileBtn, "right-0 border-r-0 next-btn"]}>
      &gt;
    </button>
  </div>

  {/* 2. DESKTOP HARDWARE CONTROLS (Hidden on Mobile) */}
  <div class:list={[
    "hidden sm:flex flex-row justify-between items-center gap-4",
    "mt-2 border-t border-industrial pt-4"
  ]}>
    
    {/* Directional Nav (Hidden during Auto-Scroll) */}
    <div class:list={[
      "nav-buttons flex gap-6 opacity-0 pointer-events-none",
      "transition-opacity duration-300"
    ]}>
      <button class:list={[desktopBtn, "prev-btn"]}>
        [ &lt;_PREV ]
      </button>
      <button class:list={[desktopBtn, "next-btn"]}>
        [ NEXT_&gt; ]
      </button>
    </div>

    {/* Explicit UX Toggle Button */}
    <button class:list={[
      "toggle-btn font-mono text-sm text-accent border border-accent/30",
      "bg-accent/5 px-4 py-2 hover:bg-accent/10 hover:border-accent",
      "transition-all uppercase tracking-widest flex items-center",
      "gap-3 group"
    ]}>
      <span class="status-dot w-2 h-2 rounded-full bg-accent animate-pulse">
      </span>
      <span class="btn-text">
        [ SYS_STATUS: AUTO_SCROLL | CLICK_TO_INTERCEPT ]
      </span>
    </button>
    
  </div>

</sys-carousel>

{/* --- CSS: SCROLLBARS & STATE --- */}
<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .nav-active {
    opacity: 1 !important;
    pointer-events: auto !important;
  }
</style>

{/* --- JS: BIDIRECTIONAL INFINITE CAROUSEL LOGIC --- */}
<script>
  import { initSysCarousel } from '../../scripts/scroll_carousel.js';

  class SysCarousel extends HTMLElement {
    connectedCallback() {
      initSysCarousel(this); 
    }
  }

  if (!customElements.get('sys-carousel')) {
    customElements.define('sys-carousel', SysCarousel);
  }
</script>