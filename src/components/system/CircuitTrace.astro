---
// src/components/system/CircuitTrace.astro
---

<div class="fixed left-8 top-12 bottom-12 w-4 z-40 pointer-events-none hidden lg:block">
  
  {/* Dim Background Track */}
  <div class="absolute left-1/2 top-0 bottom-0 w-[2px] bg-industrial -translate-x-1/2"></div>
  
  {/* "Active Signal Line" */}
  <div 
    id="main-bus-trace" 
    class="absolute left-1/2 top-0 w-[2px] bg-telemetry -translate-x-1/2 origin-top shadow-[0_0_8px_var(--color-telemetry)]"
    style="transform: scaleY(0);"
  ></div>
  
  {/* Bottom "Ground Node" */}
  <div class="absolute left-1/2 bottom-0 w-4 h-1 bg-industrial -translate-x-1/2"></div>

</div>

<script>
  const updateTrace = () => {
    const trace = document.getElementById('main-bus-trace');
    if (!trace) return;
    
    const scrollableHeight = document.documentElement.scrollHeight - window.innerHeight;
    if (scrollableHeight <= 0) return;
    
    const progress = window.scrollY / scrollableHeight;
    trace.style.transform = `translateX(-50%) scaleY(${progress})`;
  };

  window.addEventListener('scroll', updateTrace, { passive: true });
  window.addEventListener('resize', updateTrace, { passive: true });
  updateTrace();
</script>